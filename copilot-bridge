#!/usr/bin/env bash
# copilot-bridge — Programmatic wrapper around the GitHub Copilot CLI
# Docs: https://docs.github.com/en/copilot/reference/copilot-cli-reference/cli-programmatic-reference
# Install: npm install -g @github/copilot
# Usage: copilot-bridge <command> [args...]

set -euo pipefail

BOLD="\033[1m"
RESET="\033[0m"
YELLOW="\033[33m"
RED="\033[31m"

_check_copilot() {
  if ! command -v copilot &>/dev/null; then
    echo -e "${RED}Error:${RESET} 'copilot' CLI is not installed."
    echo ""
    echo "Install GitHub Copilot CLI (pick one):"
    echo "  brew install copilot-cli                   # macOS/Linux (Homebrew)"
    echo "  npm install -g @github/copilot             # all platforms (npm)"
    echo "  curl -fsSL https://gh.io/copilot-install | bash  # macOS/Linux (script)"
    echo ""
    echo "Then authenticate: copilot login"
    exit 1
  fi
}

# Core runner — flags used:
#   -p              execute prompt non-interactively, exits when done
#   -s              silent: suppress stats/decoration, output agent response only
#   --no-ask-user   prevent agent pausing for user input
#   --no-auto-update  suppress update checks during scripted runs
#   --no-color      plain-text output for scripting/piping
#   2>/dev/null     suppress stderr (as recommended in official quickstart examples)
_run() {
  local prompt="$1"; shift
  copilot -p "$prompt" -s --no-ask-user --no-auto-update --no-color "$@" 2>/dev/null
}

cmd_ask() {
  local query="$*"
  [[ -z "$query" ]] && { echo "Usage: copilot-bridge ask <question>"; exit 1; }
  _check_copilot
  # claude-haiku-4.5: fast, cost-effective for Q&A
  _run "$query" --allow-tool='read' --model=claude-haiku-4.5
}

cmd_suggest() {
  local query="$*"
  [[ -z "$query" ]] && { echo "Usage: copilot-bridge suggest <task>"; exit 1; }
  _check_copilot
  # claude-haiku-4.5: fast for simple command suggestions
  _run "Suggest a shell command to: $query. Show only the command and a one-line explanation." \
    --model=claude-haiku-4.5
}

cmd_explain() {
  local query="$*"
  [[ -z "$query" ]] && { echo "Usage: copilot-bridge explain <command>"; exit 1; }
  _check_copilot
  # claude-haiku-4.5: fast for explanations
  _run "Explain this command in plain English, breaking down each flag: $query" \
    --model=claude-haiku-4.5
}

cmd_fix() {
  local query="$*"
  [[ -z "$query" ]] && { echo "Usage: copilot-bridge fix <error or description>"; exit 1; }
  _check_copilot
  # Default model (Claude Opus 4.5): deep reasoning needed for bug fixing
  _run "Fix this error or problem: $query. Show what to change and why." \
    --allow-tool='write, shell(git:*), shell(npm run:*), read'
}

cmd_review() {
  _check_copilot

  local target="${1:-}"

  if [[ -n "$target" && -f "$target" ]]; then
    # Default model: thorough code review needs strong reasoning
    _run "/review $target — focus on bugs, logic errors, and security issues." \
      --allow-tool='shell(git:*)'
  else
    local diff
    diff="$(git diff --staged 2>/dev/null)"
    [[ -z "$diff" ]] && diff="$(git diff HEAD 2>/dev/null)"
    if [[ -z "$diff" ]]; then
      echo -e "${YELLOW}No staged changes or git diff found.${RESET} Pass a file path: copilot-bridge review <file>"
      exit 1
    fi
    _run "/review the changes on this branch compared to main. Focus on bugs and security issues." \
      --allow-tool='shell(git:*)'
  fi
}

cmd_help() {
  echo -e "${BOLD}🛩️  copilot-bridge${RESET} — Programmatic GitHub Copilot CLI wrapper"
  echo ""
  echo -e "${BOLD}Commands:${RESET}"
  printf "  %-28s %s\n" "ask <question>"       "Ask Copilot any question  [haiku]"
  printf "  %-28s %s\n" "suggest <task>"       "Get a shell command suggestion  [haiku]"
  printf "  %-28s %s\n" "explain <command>"    "Explain a shell command or snippet  [haiku]"
  printf "  %-28s %s\n" "fix <error>"          "Fix an error or bug  [opus]"
  printf "  %-28s %s\n" "review [file]"        "Review staged diff or a specific file  [opus]"
  printf "  %-28s %s\n" "help"                 "Show this help"
  echo ""
  echo -e "${BOLD}All commands run as:${RESET}"
  echo "  copilot -p '<prompt>' -s --no-ask-user --no-auto-update --no-color [--model=...] [--allow-tool=...]"
  echo ""
  echo -e "${BOLD}Examples:${RESET}"
  echo "  copilot-bridge ask 'how do I reverse a string in bash?'"
  echo "  copilot-bridge suggest 'delete all node_modules folders recursively'"
  echo "  copilot-bridge explain 'git rebase -i HEAD~3'"
  echo "  copilot-bridge fix 'permission denied when running npm install'"
  echo "  copilot-bridge review"
  echo "  copilot-bridge review src/index.ts"
  echo ""
  echo -e "${BOLD}Install (pick one):${RESET}"
  echo "  brew install copilot-cli"
  echo "  npm install -g @github/copilot"
  echo "  curl -fsSL https://gh.io/copilot-install | bash"
  echo "  Then: copilot login"
}

# ── Router ───────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  ask)            cmd_ask "$@" ;;
  suggest)        cmd_suggest "$@" ;;
  explain)        cmd_explain "$@" ;;
  fix)            cmd_fix "$@" ;;
  review)         cmd_review "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command:${RESET} $COMMAND"
    echo "Run 'copilot-bridge help' for usage."
    exit 1
    ;;
esac
